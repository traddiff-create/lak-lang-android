{
  "name": "laklang-lm",
  "version": "0.1.0",
  "description": "Lakota Language Learning Platform",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/app.ts",
    "start": "node --import tsx/esm server/app.ts",
    "build": "vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx data/seed/import.ts",
    "parse-primer": "tsx data/seed/parse-primer.ts",
"ingest-graph": "tsx data/seed/ingest-graph.ts",
"ingest-csd": "tsx data/seed/ingest-csd.ts",
"ingest-deloria": "tsx data/seed/ingest-deloria.ts",
"ingest-corpus": "tsx data/seed/ingest-corpus.ts",
"ingest-williamson": "tsx data/seed/ingest-williamson.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.0",
    "node-html-parser": "^7.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-router-dom": "^6.28.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
